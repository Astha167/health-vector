# =============================================================================
# Health Vector — Backend environment template
# =============================================================================
# Copy this file to `server/.env` for local development.
# In production, set these as environment variables on Render
# (Dashboard → your service → Environment).
# Never commit your real `.env` file.
# =============================================================================

# ---- Server ----
# Local dev: 3001 (frontend Vite dev server runs on 5000 and proxies /api here)
# Render:    leave PORT unset — Render injects it automatically
PORT=3001
NODE_ENV=development

# ---- MongoDB Atlas ----
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# Network Access → Add IP → Allow Access From Anywhere (0.0.0.0/0)
# Database Access → Create user → copy the SRV connection string below
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/healthvector?retryWrites=true&w=majority

# ---- JWT ----
# Use a long random string (e.g. `openssl rand -hex 64`)
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- CORS / Frontend URL ----
# Comma-separated list of allowed frontend origins (no trailing slash).
# Local dev:  http://localhost:5000
# Production: your Vercel URL, e.g. https://health-vector.vercel.app
# You can list both for preview environments.
CLIENT_URL=http://localhost:5000,https://your-app.vercel.app

# ---- Email (Nodemailer) — optional ----
# Used by contact form and password-reset emails.
# Leave SMTP_USER/SMTP_PASS blank to log emails to the console instead of sending.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Destination address for contact-form submissions
ADMIN_EMAIL=admin@example.com
